{
  "name": "stacks-cli",
  "version": "0.1.0",
  "description": "MCP-native CLI for the Stacks blockchain",
  "type": "module",
  "bin": {
    "stacks": "./bin/run.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "mcp": "node dist/mcp/server.js",
    "lint": "eslint src --ext .ts",
    "postpack": "shx rm -f oclif.manifest.json",
    "prepack": "oclif manifest && oclif readme"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@oclif/core": "^4.0.0",
    "@scure/bip32": "^2.0.1",
    "@stacks/blockchain-api-client": "^8.0.0",
    "@stacks/network": "^6.17.0",
    "@stacks/stacking": "^6.17.0",
    "@stacks/transactions": "^6.17.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "oclif": "^4.0.0",
    "shx": "^0.3.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "oclif": {
    "bin": "stacks",
    "dirname": "stacks",
    "commands": "./dist/commands",
    "topicSeparator": ":",
    "plugins": []
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "stacks",
    "blockchain",
    "cli",
    "mcp",
    "bitcoin",
    "sbtc"
  ],
  "license": "MIT"
}
